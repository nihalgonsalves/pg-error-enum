{
  "name": "pg-error-enum",
  "version": "2.0.1",
  "description": "TypeScript Enum for Postgres Errors with no runtime dependencies",
  "homepage": "https://github.com/nihalgonsalves/pg-error-enum#readme",
  "bugs": {
    "url": "https://github.com/nihalgonsalves/pg-error-enum/issues"
  },
  "license": "MIT",
  "author": "Nihal Gonsalves <nihal@nihalgonsalves.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nihalgonsalves/pg-error-enum.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "sync": "node bin/sync.ts",
    "clean": "rm -rf ./dist/",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.build.json",
    "build": "tsc --build tsconfig.build.json",
    "lint:check": "oxlint",
    "format:check": "oxfmt --check",
    "format:write": "oxfmt",
    "prepublishOnly": "npm run build",
    "test": "node bin/test.js"
  },
  "devDependencies": {
    "@nihalgonsalves/esconfig": "^0.17.4",
    "@types/node": "^22",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "^22.12.0 || >24.0.0"
  },
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd"
}
